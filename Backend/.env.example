PORT=5000
# Local MongoDB example:
MONGODB_URI=mongodb://127.0.0.1:27017/cheque_printer
# Atlas SRV example:
# MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/cheque_printer?retryWrites=true&w=majority&appName=Cluster0
# Atlas standard URI example:
# MONGODB_URI=mongodb://username:password@cluster-shard-00-00.example.mongodb.net:27017,cluster-shard-00-01.example.mongodb.net:27017,cluster-shard-00-02.example.mongodb.net:27017/cheque_printer?ssl=true&replicaSet=atlas-xxxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
# Optional for SRV DNS issues:
# MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1
CLIENT_URL=http://localhost:3000
JWT_SECRET=replace_with_a_long_random_secret
GMAIL_USER=
GMAIL_APP_PASSWORD=
MAIL_FROM=
