PORT=5000
JWT_SECRET=replace_with_a_long_random_secret
CLIENT_URL=http://localhost:3000

# Option 1: provide a full MongoDB connection string
MONGODB_URI=mongodb+srv://<username>:<url_encoded_password>@<cluster-host>/<db_name>?retryWrites=true&w=majority

# Option 2: provide raw MongoDB parts instead of a full URI
# MONGODB_HOSTS=<cluster-host>
# MONGODB_USERNAME=<username>
# MONGODB_PASSWORD=<raw_password_with_special_characters_allowed>
# MONGODB_DB_NAME=cheque_printer
# MONGODB_AUTHSOURCE=admin

GMAIL_USER=your_email@example.com
GMAIL_APP_PASSWORD=your_app_password
MAIL_FROM=your_email@example.com
