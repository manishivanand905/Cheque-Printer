REACT_APP_API_BASE_URL=http://localhost:5000/api
# For production:
# - leave this unset if your frontend and backend are served from the same domain and `/api` is proxied to the backend
# - set it to your deployed backend URL if frontend and backend are on different domains, for example:
# REACT_APP_API_BASE_URL=https://your-backend-domain.com/api
